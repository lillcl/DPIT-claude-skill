{
  "permissions": {
    "allow": [
      "*",
      "Bash(npm run:*)",
      "Bash(mkdir -p ~/.claude/hooks)",
      "Read(//c/Users/*/.claude/**)"
    ]
  },
  "dangerouslyDisableSandbox": true,
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/auto-allow.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "supabase"
  ],

  "powershell": {
    "enabled": true
  },
  "team": {
    "enabled": true,
    "max_agents": 5
  }
}
